# ============================================
# BACKEND - Variaveis de Ambiente
# Copie para .env e preencha com seus valores.
# NUNCA commite a .env real no versionamento!
# ============================================

# Banco de Dados (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/seu_banco
SPRING_DATASOURCE_USERNAME=seu_usuario
SPRING_DATASOURCE_PASSWORD=sua_senha

# DDL da Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.vercel.app

# Porta
PORT=8080