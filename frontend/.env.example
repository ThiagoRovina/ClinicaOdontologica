# ============================================
# FRONTEND - React (Create React App)
# Copie para .env e preencha com seus valores.
# NUNCA commite a .env real no versionamento!
# ============================================

# URL da API do backend (produção = URL do Render)
REACT_APP_API_ORIGIN=http://localhost:8080

# ============================================
# Como usar com Vercel:
# 1. Crie as variaveis em: vercel.com > projeto > Settings > Environment Variables
# 2. Nome: REACT_APP_API_ORIGIN
# 3. Valor: https://seu-backend.onrender.com
# 4. Ambiente: Production (e Preview se quiser)
#
# Como usar com Render:
# 1. Ambiente > Environment > Variables
# 2. DATABASE_URL = jdbc:postgresql://...
# 3. SPRING_DATASOURCE_USERNAME / PASSWORD
# ============================================